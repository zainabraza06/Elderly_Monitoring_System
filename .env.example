# SafeStep AI — backend environment (copy to `.env` in this repo root).
# Loaded automatically when you run: uvicorn flask_backend.app.main:app (see flask_backend/app/main.py).

# Required in production (keep secret). Dev default in code is insecure.
JWT_SECRET=change-me-to-a-long-random-string

# Optional: paths to ML artifacts (defaults: flask_backend/models/ and inference_manifest.json inside it)
# MODEL_ROOT=
# INFERENCE_MANIFEST=

# First-run admin user when DB has no admin (SQLite seed). Change after login.
ADMIN_EMAIL=admin@local
ADMIN_PASSWORD=admin123

# Escalation timings (seconds)
FALL_RESPONSE_DEADLINE_SEC=30
FALL_EMERGENCY_DEADLINE_SEC=90
